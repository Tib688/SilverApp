{
  "name": "silverapp",
  "version": "2.3.4",
  "description": "Silver Bot Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.js"
  },
  "author": "Tib",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.tib.silverapp",
    "productName": "Silver App",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "zip",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "Silver App",
      "uninstallDisplayName": "Silver App",
      "include": "build/installer.nsh"
    },
    "directories": {
      "output": "App"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "backend/**/*"
    ]
  }
}
